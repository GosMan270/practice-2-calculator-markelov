<Window x:Class="CalculatorMarkelov.Wpf.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="CalculatorMarkelov"
        Height="420"
        Width="620"
        MinHeight="420"
        MinWidth="620"
        WindowStartupLocation="CenterScreen"
        Background="#FFF5F7FA">

    <Window.Resources>
        <Style x:Key="LabelStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="0,0,0,6"/>
            <Setter Property="Foreground" Value="#223046"/>
        </Style>

        <Style x:Key="InputStyle" TargetType="Control">
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="Height" Value="38"/>
            <Setter Property="Margin" Value="0,0,0,14"/>
        </Style>

        <Style x:Key="ActionButtonStyle" TargetType="Button">
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Height" Value="42"/>
            <Setter Property="MinWidth" Value="120"/>
            <Setter Property="Margin" Value="0,0,10,0"/>
            <Setter Property="Padding" Value="18,8"/>
            <Setter Property="Background" Value="#2D72D9"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#2D72D9"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>

        <Style x:Key="SecondaryButtonStyle" TargetType="Button" BasedOn="{StaticResource ActionButtonStyle}">
            <Setter Property="Background" Value="#E1E7F0"/>
            <Setter Property="Foreground" Value="#223046"/>
            <Setter Property="BorderBrush" Value="#D3DCE8"/>
        </Style>
    </Window.Resources>

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="18"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="18"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Background="White"
                BorderBrush="#D9E2EC"
                BorderThickness="1"
                CornerRadius="14"
                Padding="20">
            <StackPanel>
                <TextBlock Text="Калькулятор"
                           FontSize="28"
                           FontWeight="Bold"
                           Foreground="#1C2736"/>
                <TextBlock Margin="0,8,0,0"
                           FontSize="14"
                           Foreground="#5B6B7F"
                           Text="Арифметические операции: +, -, *, /, ^"/>
            </StackPanel>
        </Border>

        <Border Grid.Row="2"
                Background="White"
                BorderBrush="#D9E2EC"
                BorderThickness="1"
                CornerRadius="14"
                Padding="20">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="24"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <TextBlock Text="Первое число" Style="{StaticResource LabelStyle}"/>
                    <TextBox x:Name="txtFirstNumber"
                             Style="{StaticResource InputStyle}"
                             VerticalContentAlignment="Center"
                             ToolTip="Введите первое число"/>

                    <TextBlock Text="Операция" Style="{StaticResource LabelStyle}"/>
                    <ComboBox x:Name="cmbOperation"
                              Style="{StaticResource InputStyle}"
                              SelectedIndex="0">
                        <ComboBoxItem Content="+"/>
                        <ComboBoxItem Content="-"/>
                        <ComboBoxItem Content="*"/>
                        <ComboBoxItem Content="/"/>
                        <ComboBoxItem Content="^"/>
                    </ComboBox>

                    <TextBlock Text="Второе число" Style="{StaticResource LabelStyle}"/>
                    <TextBox x:Name="txtSecondNumber"
                             Style="{StaticResource InputStyle}"
                             VerticalContentAlignment="Center"
                             ToolTip="Введите второе число"/>

                    <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                        <Button x:Name="btnCalculate"
                                Content="Вычислить"
                                Style="{StaticResource ActionButtonStyle}"
                                Click="BtnCalculate_Click"/>
                        <Button x:Name="btnClear"
                                Content="Очистить"
                                Style="{StaticResource SecondaryButtonStyle}"
                                Click="BtnClear_Click"/>
                    </StackPanel>
                </StackPanel>

                <Border Grid.Column="2"
                        Background="#F8FAFC"
                        BorderBrush="#E2E8F0"
                        BorderThickness="1"
                        CornerRadius="12"
                        Padding="18">
                    <StackPanel>
                        <TextBlock Text="Результат"
                                   FontSize="18"
                                   FontWeight="Bold"
                                   Foreground="#1C2736"/>
                        <TextBox x:Name="txtResult"
                                 Margin="0,14,0,12"
                                 FontSize="24"
                                 FontWeight="Bold"
                                 Height="54"
                                 IsReadOnly="True"
                                 VerticalContentAlignment="Center"
                                 Background="White"
                                 BorderBrush="#CBD5E1"/>

                        <TextBlock Text="Служебное сообщение"
                                   Style="{StaticResource LabelStyle}"
                                   Margin="0,8,0,6"/>
                        <TextBlock x:Name="txtStatus"
                                   Text="Готов к работе."
                                   FontSize="14"
                                   TextWrapping="Wrap"
                                   Foreground="#475569"
                                   MinHeight="56"/>

                        <Separator Margin="0,16,0,16"/>

                        <TextBlock Text="Подсказка"
                                   FontSize="16"
                                   FontWeight="SemiBold"
                                   Foreground="#1C2736"/>
                        <TextBlock Margin="0,8,0,0"
                                   FontSize="13"
                                   TextWrapping="Wrap"
                                   Foreground="#5B6B7F"
                                   Text="Введите два числа, выберите операцию и нажмите кнопку «Вычислить». Для десятичных значений можно использовать точку или запятую."/>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <Border Grid.Row="4"
                Background="#EEF4FF"
                BorderBrush="#D6E4FF"
                BorderThickness="1"
                CornerRadius="12"
                Padding="14">
            <TextBlock Text="Практическая работа 2 • WPF-приложение + библиотека классов + модульные тесты"
                       FontSize="13"
                       Foreground="#35507A"
                       HorizontalAlignment="Center"/>
        </Border>
    </Grid>
</Window>
